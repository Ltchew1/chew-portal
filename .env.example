# Real values go into Vercel's Environment Variables settings ONLY —
# never into this file, never committed to GitHub.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_in_vercel_only
CLERK_SECRET_KEY=sk_test_replace_in_vercel_only

# Where users land after signing in/up — keep as-is for this setup.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Powers CHEW Guidance (the AI chat). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace_in_vercel_only
